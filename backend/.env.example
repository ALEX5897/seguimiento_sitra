# Configuración de Base de Datos
DB_HOST=172.16.1.63
DB_USER=us_segdoc
DB_PASS=@2BKb+0sJX!5
DB_NAME=seguimiento_sitra

# Configuración de Correo (Outlook Office365)
MAIL_HOST=outlook.office365.com
MAIL_PORT=587
MAIL_USER=tu-email@empresa.com
MAIL_PASS=tu-contraseña-de-aplicación

# Configuración del Servidor
PORT=3000
NODE_ENV=production

# Configuración del Cronjob
# Formato cron: segundo minuto hora día_mes mes día_semana
# Ejemplos:
# 0 8 * * * = Cada día a las 08:00 (8 AM)
# 0 9 * * * = Cada día a las 09:00 (9 AM)
# 0 */6 * * * = Cada 6 horas
CRON_SCHEDULE=0 8 * * *

# Zona horaria para el cronjob
# Opciones: America/Argentina/Buenos_Aires, America/New_York, Europe/Madrid, etc.
TIMEZONE=America/Argentina/Buenos_Aires

# URL base del frontend para links en correos y CORS
FRONTEND_URL=http://172.16.1.63
CORS_ORIGIN=http://172.16.1.63

# Sesiones (HTTP en produccion)
SESSION_SECRET=cambiar-por-secret-seguro-generado-con-openssl
SESSION_SECURE=false
SESSION_SAMESITE=lax

# Keycloak - Autenticación y sincronización de usuarios
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=http://tu-keycloak:8080
KEYCLOAK_REALM=tu-realm
KEYCLOAK_CLIENT_ID=sistra-app
KEYCLOAK_CLIENT_SECRET=
# Nota: El CLIENT_SECRET se necesita para sincronizar usuarios desde Keycloak diariamente
# Los usuarios deben tener atributos personalizados en Keycloak:
#   - cargo: Posición del empleado
#   - gerencia: Departamento/Área del empleado
#   - telefono: Número de teléfono del empleado
